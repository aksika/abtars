# Unified API transport — OpenRouter primary, Ollama cloud fallback
AGENT_CLI=api
AGENT_TRANSPORT=api

# Primary: OpenRouter (qwen3.6-plus free, 1M context)
API_ENDPOINT=https://openrouter.ai/api/v1
API_KEY=
API_MODEL=qwen/qwen3.6-plus:free
API_MAX_CONTEXT=1000000

# Fallback 1: OpenRouter different provider (196K)
API_FALLBACK_1_ENDPOINT=https://openrouter.ai/api/v1
API_FALLBACK_1_KEY=
API_FALLBACK_1_MODEL=minimax/minimax-m2.5:free
API_FALLBACK_1_MAX_CONTEXT=196608

# Fallback 2: Ollama cloud (256K)
API_FALLBACK_2_ENDPOINT=http://localhost:11434/v1
API_FALLBACK_2_MODEL=kimi-k2.5:cloud
API_FALLBACK_2_MAX_CONTEXT=262144

# Fallback 3: Ollama cloud alternate (128K)
API_FALLBACK_3_ENDPOINT=http://localhost:11434/v1
API_FALLBACK_3_MODEL=minimax-m2.5:cloud
API_FALLBACK_3_MAX_CONTEXT=131072

# Last resort: swap to ACP (kiro)
TRANSPORT_FALLBACK=acp

# Sub-agent models
AGENT_BROWSE_MODEL=minimax/minimax-m2.5:free
AGENT_SLEEP_MODEL=minimax/minimax-m2.5:free
AGENT_CODING_MODEL=qwen/qwen3-coder:free
AGENT_SLEEP_CTX_WINDOW=196608
