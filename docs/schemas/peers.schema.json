{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "abtars peers.json",
  "type": "object",
  "required": ["self", "peers"],
  "properties": {
    "self": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "signingKey": { "type": "string", "description": "Base64 Ed25519 private key for message signing" }
      }
    },
    "peers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["host", "port", "verifyKey"],
        "properties": {
          "host": { "type": "string" },
          "port": { "type": "number" },
          "verifyKey": { "type": "string", "description": "Base64 Ed25519 public key for signature verification" },
          "trust": { "type": "number", "description": "Trust level: 0=enrolled, 1=trusted, 2=owner" },
          "mode": { "type": "string", "enum": ["signed"] },
          "allowedTools": { "type": "array", "items": { "type": "string" } },
          "allowedRead": { "type": "array", "items": { "type": "string" } },
          "allowedWrite": { "type": "array", "items": { "type": "string" } },
          "transport": { "type": "string", "enum": ["http", "ws-outbound"] }
        }
      }
    },
    "maxHops": { "type": "number" },
    "timeoutMs": { "type": "number" }
  }
}
