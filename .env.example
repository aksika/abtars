# ============================================================
# Telegram Bot Configuration (required)
# ============================================================

# Telegram Bot API token from @BotFather
# Format: <bot_id>:<token_string> e.g. 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# Primary delivery channel — cron results, system notifications, task reports
# Telegram chatId of the master user. Auth comes from config/users.json.
# MAIN_CHAT_ID=

# Telegram long-poll timeout in seconds (default: 30)
# POLL_TIMEOUT_S=30

# Streaming flush interval in seconds (default: 3)
# STREAM_FLUSH_SEC=3

# ============================================================
# Discord App Configuration (optional — Discord disabled if token absent)
# ============================================================

# Discord bot token from Discord Developer Portal → Bot tab → Reset Token
# DISCORD_BOT_TOKEN=

# Discord Application ID from Developer Portal → General Information
# DISCORD_APP_ID=

# Comma-separated Discord channel IDs where the bot can respond (* = all)
# DISCORD_ALLOWED_CHANNEL_IDS=*

# ============================================================
# Transport & Model Configuration
# ============================================================

# Transport/model config files (relative to ~/.agentbridge/config/)
TRANSPORT_CONFIG=config/transport.json
MODELS_CONFIG=config/models.json

# Emergency fallback when primary + configured fallbacks all fail
DEFAULT_PROVIDER=openrouter
DEFAULT_TRANSPORT=api
DEFAULT_MODEL=gemini-2.5-flash
# API_DEFAULT_CONTEXT=128000

# ============================================================
# Bridge Settings
# ============================================================

# Working directory where the agent operates on your project
WORKING_DIR=~/.agentbridge/workspace

# Auto-approve all permission requests (default: false)
# tmux transport: always trust mode (can't intercept structured permission requests)
# acp transport: set to "true" for auto-approve, "false" for interactive Telegram prompts
TRUST_MODE=true

# Timeout in ms for interactive permission prompts — acp transport only (default: 60000)
# PERMISSION_TIMEOUT_MS=60000

# ============================================================
# Logging
# ============================================================

# Log level: "off" (silent), "low" (operational info), "debug" (full message content)
LOG_LEVEL=low

# ============================================================
# Sleep Schedule
# ============================================================

# Time to start sleep routine (HH:MM, 24h format)
BED_TIME=02:00

# Time to wake up (HH:MM, 24h format)
WAKE_TIME=07:00

# Consecutive idle heartbeat ticks before sleep is allowed (default: 2)
BED_QUIET_TICKS=2

# Put machine to hardware sleep after dreamy finishes (default: false)
# HARDWARE_SLEEP_AFTER_DREAMY=false

# Max minutes for sleep routine before timeout (default: 90)
# SLEEP_TIMEOUT_MIN=90

# ============================================================
# Speech-to-Text (STT) — Voice Note Transcription
# ============================================================

# Groq API key for Whisper STT (optional — voice notes ignored without it)
# GROQ_API_KEY=

# ============================================================
# Text-to-Speech (TTS) — Voice Note Replies
# ============================================================

# Enable/disable TTS voice replies to voice notes (default: true)
# TTS_ENABLED=true

# Edge TTS voice (default: en-US-AndrewMultilingualNeural)
# TTS_VOICE=en-US-AndrewMultilingualNeural

# ============================================================
# Web Dashboard (optional — enabled with --web or --all flag)
# ============================================================

# Port for the web dashboard HTTP server (default: 3000)
# WEB_PORT=3000

# Host/IP to bind the web dashboard server (default: 127.0.0.1)
# WEB_HOST=127.0.0.1

# Bearer token for dashboard API and WebSocket authentication
# Generate a secure random token: openssl rand -hex 32
# WEB_AUTH_TOKEN=

# ============================================================
# Agent API (optional — enabled with --agent flag)
# ============================================================

# Port for the agent REST API (default: 3001)
# AGENT_API_PORT=3001

# Comma-separated IPs allowed to call the agent API
# AGENT_API_ALLOWED_IPS=

# Bearer token for agent API authentication (optional)
# AGENT_API_TOKEN=
ABMIND_HOME=~/.abmind

# Memory (abmind) — detailed config in ~/.abmind/config/.env.memory
# MEMORY_ENABLED=true
