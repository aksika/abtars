# AgentBridge Environment Variables
# Generated from env-schema.ts — copy to ~/.agentbridge/config/.env and customize.
# Interactive setup: `agentbridge onboard`.

# =====================================================================
# Core
# =====================================================================

# Primary Telegram chat ID for cron results + system notifications
MAIN_CHAT_ID=

# Agent working directory (default: ~/.agentbridge/workspace — the agent's sandbox)
# WORKING_DIR=

# Log level: off (silent), low (operational info), debug (full message content) (default: low)
# LOG_LEVEL=low

# Log format: text (human-readable) or json (structured) (default: text)
# LOG_FORMAT=text

# =====================================================================
# Transport
# =====================================================================

# Transport type: api (direct HTTP), acp (CLI process), tmux (default: api)
# AGENT_TRANSPORT=api

# Agent CLI name when transport=acp: kiro or gemini (default: kiro)
# AGENT_CLI=kiro

# Tmux session name when transport=tmux (default: kiro)
# TMUX_SESSION=kiro

# Default provider used if transport.json missing (default: api)
# DEFAULT_TRANSPORT=api

# Default provider name for transport.json fallback
DEFAULT_PROVIDER=

# Default model when config/transport.json is missing
DEFAULT_MODEL=

# Transport config filename in ~/.agentbridge/config/ (default: transport.json)
# TRANSPORT_CONFIG=transport.json

# Models catalog filename in ~/.agentbridge/config/ (default: models.json)
# MODELS_CONFIG=models.json

# =====================================================================
# Transport timeouts + watchdog
# =====================================================================

# ACP prompt timeout in seconds (default: 180)
# PROMPT_TIMEOUT_SEC=180

# Direct API model response timeout in ms (default: 120000)
# MODEL_API_TIMEOUT_MS=120000

# Watchdog timeout for a single tool call in seconds (default: 180)
# WATCHDOG_TOOL_TIMEOUT_SEC=180

# Watchdog timeout for silent/stalled model output in seconds (default: 300)
# WATCHDOG_SILENT_SEC=300

# Watchdog timeout for runaway prompts in seconds (default: 600)
# WATCHDOG_ENDLESS_SEC=600

# =====================================================================
# Telegram (required for Telegram platform)
# =====================================================================

# Telegram bot token from @BotFather (format: <id>:<secret>)
TELEGRAM_BOT_TOKEN=

# Telegram API timeout in ms — basic API calls (default: 15000)
# TELEGRAM_TIMEOUT_MS=15000

# Telegram long-poll timeout in seconds (default: 30)
# POLL_TIMEOUT_S=30

# Telegram file up/download timeout in ms (default: 60000)
# TELEGRAM_FILE_TIMEOUT_MS=60000

# =====================================================================
# Discord (optional — Discord disabled if bot token absent)
# =====================================================================

# Discord bot token from Developer Portal
DISCORD_BOT_TOKEN=

# Discord application ID from Developer Portal
DISCORD_APP_ID=

# Discord A2A (agent-to-agent) channel ID — niche, usually unset
DISCORD_A2A_CHANNEL_ID=

# Discord A2A peer bot ID — required if A2A_CHANNEL_ID set
DISCORD_A2A_PEER_BOT_ID=

# Discord A2A rate limit in ms (default: 5000)
# DISCORD_A2A_RATE_LIMIT_MS=5000

# =====================================================================
# Provider API keys (set the one matching DEFAULT_PROVIDER)
# =====================================================================

# OpenRouter — https://openrouter.ai
OPENROUTER_API_KEY=

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=

# Ollama Cloud (optional, localhost doesn't need one)
OLLAMA_API_KEY=

# Kiro CLI
KIRO_API_KEY=

# Gemini CLI
GEMINI_API_KEY=

# =====================================================================
# Context window management
# =====================================================================

# Context % to warn user before auto-compact (default: 70)
# CTX_WARN_PCT=70

# Context % to trigger auto-compact (default: 80)
# CTX_COMPACT_PCT=80

# Context % for aggressive compaction (default: 90)
# CTX_AGGRESSIVE_PCT=90

# Context % for floating idle compaction (default: 65)
# CTX_IDLE_COMPACT_PCT=65

# Minutes idle before triggering floating compaction (default: 10)
# CTX_IDLE_COMPACT_MIN=10

# =====================================================================
# UI / streaming
# =====================================================================

# Typing indicator TTL in ms (default: 300000)
# TYPING_TTL_MS=300000

# Silence threshold before 'still working' message in ms (default: 90000)
# TYPING_SILENT_THRESHOLD_MS=90000

# Stream edit flush interval in seconds, 0=disabled (default: 3)
# STREAM_FLUSH_SEC=3

# =====================================================================
# Memory
# =====================================================================

# Enable ambient recall on every turn (default: false)
# ACTIVE_MEMORY=false

# Use model-generated topics for priming (default: true)
# PRIMING_MODEL_TOPICS=true

# =====================================================================
# Sleep schedule
# =====================================================================

# Daily sleep trigger time, H:MM or HH:MM (default: 0:30)
# BED_TIME=0:30

# Wake time for platform detection, H:MM or HH:MM (default: 7:00)
# WAKE_TIME=7:00

# Quiet heartbeat ticks (×5min) before sleep is allowed (default: 2)
# BED_QUIET_TICKS=2

# Put machine to hardware sleep after Dreamy finishes (default: false)
# HARDWARE_SLEEP_AFTER_DREAMY=false

# Max minutes for sleep routine before timeout (default: 90)
# SLEEP_TIMEOUT_MIN=90

# Model override for the Dreamy sleep agent
SLEEP_MODEL=

# Sleep quality override
SLEEP_QUALITY=

# =====================================================================
# Voice (STT / TTS)
# =====================================================================

# Enable speech-to-text for voice notes (default: false)
# STT_ENABLED=false

# STT provider API key — Groq for Whisper
GROQ_API_KEY=

# STT model name (default: whisper-large-v3-turbo)
# STT_MODEL=whisper-large-v3-turbo

# Enable text-to-speech voice replies (default: false)
# TTS_ENABLED=false

# TTS voice name (default: alloy)
# TTS_VOICE=alloy

# =====================================================================
# Self-healer
# =====================================================================

# Enable auto-fix heartbeat task (default: false)
# SELFHEAL_ENABLED=false

# =====================================================================
# Browser (optional — web browsing skill)
# =====================================================================

# Browser engine: patchright, chromium (default: patchright)
# BROWSER_ENGINE=patchright

# Run browser headed (visible window) for debugging (default: false)
# BROWSER_HEADED=false

# Disable browser sandbox (needed in Docker/root, risky) (default: false)
# BROWSER_NO_SANDBOX=false

# Browser channel, e.g. chrome
BROWSER_CHANNEL=

# Use Docker container for browser (default: false)
# BROWSER_DOCKER=false

# Minutes idle before stopping browser container (default: 10)
# BROWSER_IDLE_STOP_MIN=10

# Comma-separated domain allowlist for web_browse
BROWSER_ALLOWED_DOMAINS=

# Max concurrent browser sessions (default: 3)
# BROWSER_MAX_SESSIONS=3

# Browser session timeout in ms (default: 300000)
# BROWSER_SESSION_TIMEOUT_MS=300000

# User agent for web scraping
WEB_SCRAPE_USER_AGENT=

# Playwright page timeout in ms (default: 30000)
# WEB_SCRAPE_PLAYWRIGHT_TIMEOUT_MS=30000

# Enable SSRF protection for outbound HTTP (default: true)
# SSRF_CHECK=true

# Model override for the browsing agent
BROWSING_AGENT=

# =====================================================================
# Misc
# =====================================================================

# Comma-separated capability names to disable at boot
DISABLED_CAPABILITIES=

# Model override for coding mode
CODING_MODEL=

# Custom dashboard module path
DASHBOARD_MODULE=

# Enable NotebookLM integration (default: false)
# NOTEBOOKLM_ENABLED=false

# Default NotebookLM notebook
NOTEBOOKLM_DEFAULT_NOTEBOOK=

# Permission prompt timeout in ms — ACP only (default: 60000)
# PERMISSION_TIMEOUT_MS=60000

# Auto-approve all permission requests — no user confirmation (default: false)
# TRUST_MODE=false

# =====================================================================
# Web dashboard (only with --web flag)
# =====================================================================

# Port for the web dashboard HTTP server (default: 3000)
# WEB_PORT=3000

# Host/IP to bind the web dashboard server (default: 127.0.0.1)
# WEB_HOST=127.0.0.1

# Bearer token for dashboard auth — auto-generated on first install if blank
WEB_AUTH_TOKEN=

# =====================================================================
# Agent API (only with --agent flag)
# =====================================================================

# Port for the agent REST API (default: 3001)
# AGENT_API_PORT=3001

# Comma-separated IPs allowed to call the agent API
AGENT_API_ALLOWED_IPS=

# Bearer token for agent API authentication
AGENT_API_TOKEN=
