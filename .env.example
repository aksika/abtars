# ============================================================
# Telegram (required)
# ============================================================

TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=
# Primary delivery channel — cron results, system notifications, task reports
# Telegram chatId of the master user (defaults to first ALLOWED_USER_IDS)
# MAIN_CHAT_ID=
# POLL_TIMEOUT_S=30
# STREAM_FLUSH_SEC=3

# ============================================================
# Discord (optional)
# ============================================================

# DISCORD_BOT_TOKEN=
# DISCORD_APP_ID=
# DISCORD_ALLOWED_USER_IDS=
# DISCORD_ALLOWED_CHANNEL_IDS=

# ============================================================
# Transport + Models (JSON config in config/)
# ============================================================

TRANSPORT_CONFIG=config/transport.json
MODELS_CONFIG=config/models.json

# Emergency fallback (used when JSON parse fails)
DEFAULT_PROVIDER=openrouter
DEFAULT_TRANSPORT=api
DEFAULT_MODEL=minimax-m2.5:cloud

# ============================================================
# Bridge Settings
# ============================================================

WORKING_DIR=~/.agentbridge/workspace
TRUST_MODE=true
LOG_LEVEL=low

# ============================================================
# Sleep / Bedtime
# ============================================================

BED_TIME=02:00
WAKE_TIME=07:00
BED_QUIET_TICKS=2
# HARDWARE_SLEEP_AFTER_DREAMY=false
# SLEEP_TIMEOUT_MIN=90

# ============================================================
# Web Dashboard (optional — enabled with --web flag)
# ============================================================

# WEB_PORT=3000
# WEB_HOST=127.0.0.1
# WEB_AUTH_TOKEN=

# ============================================================
# Agent API (optional — enabled with --agent flag)
# ============================================================

# AGENT_API_PORT=3001
# AGENT_API_ALLOWED_IPS=
# AGENT_API_TOKEN=
