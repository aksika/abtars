# ============================================================
# Telegram Bot Configuration (required)
# ============================================================

# Telegram Bot API token from @BotFather (required)
# Format: <bot_id>:<token_string> e.g. 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot (required, at least one)
# Find your user ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# Telegram long-poll timeout in seconds (default: 30)
POLL_TIMEOUT_S=30

# ============================================================
# Agent CLI Configuration
# ============================================================

# Transport profile: loads transports/<name>.env (overrides AGENT_* vars below)
# Available: kiro, gemini, openrouter, ollama, 9router
AGENT_TRANSPORT_PROFILE=kiro

# Which CLI to use: "kiro" (default), "gemini", or path to any ACP-compatible CLI
AGENT_CLI=kiro

# Transport: "acp" (recommended), "api" (direct API), or "tmux" (kiro only)
AGENT_TRANSPORT=acp

# Path to CLI binary (default: auto-detected from AGENT_CLI)
# AGENT_CLI_PATH=kiro-cli

# Working directory where the agent operates (default: current directory)
WORKING_DIR=.

# Auto-approve all agent actions (default: true)
TRUST_MODE=true

# Available models for /models command (ACP transport — no auto-discovery)
AGENT_AVAILABLE_MODELS=auto,claude-opus-4.6,claude-sonnet-4.6,claude-opus-4.5,claude-sonnet-4.5,claude-sonnet-4,claude-haiku-4.5,minimax-m2.5,minimax-m2.1,qwen3-coder-next

# ── Direct API Transport (only used when AGENT_TRANSPORT=api) ───────────────
# API_ENDPOINT=http://localhost:20128/v1
# API_KEY=
# API_MODEL=kimi-k2
# API_MAX_CONTEXT=131072
# API_MAX_OUTPUT=8192
# API_MAX_TURNS=50

# Fallback models within same transport (tried in order if primary fails)
# API_FALLBACK_1_ENDPOINT=https://openrouter.ai/api/v1
# API_FALLBACK_1_KEY=sk-or-...
# API_FALLBACK_1_MODEL=anthropic/claude-sonnet-4

# ── Cross-Transport Fallback ────────────────────────────────────────────────
# If primary transport fails entirely, swap to this transport type
# TRANSPORT_FALLBACK=acp

# ── Models ──────────────────────────────────────────────────────────────────
# Main conversation model
AGENT_MODEL=claude-sonnet-4.6

# Browse subagent model
AGENT_BROWSE_MODEL=claude-sonnet-4.6

# Sleep/memory subagent model
AGENT_SLEEP_MODEL=claude-opus-4.6

# Coding subagent model
AGENT_CODING_MODEL=claude-opus-4.6

# ============================================================
# tmux Transport Settings (only used when AGENT_TRANSPORT=tmux)
# ============================================================

# tmux session name (default: "kiro-bridge")
TMUX_SESSION=kiro-bridge

# Seconds to wait after sending a command before first capture (default: 3)
TMUX_CAPTURE_DELAY_SEC=3

# Max seconds to wait for agent to finish responding (default: 300)
TMUX_MAX_WAIT_SEC=300

# ============================================================
# Permission Settings
# ============================================================

# Timeout in ms for interactive permission prompts — acp transport only (default: 60000)
PERMISSION_TIMEOUT_MS=60000

# ============================================================
# Logging
# ============================================================

# Log level: "off" (silent), "low" (operational info), "debug" (full message content)
LOG_LEVEL=low

# ============================================================
# Speech-to-Text (STT) — Voice Note Transcription
# ============================================================

# Groq API key for Whisper STT (enables voice note transcription)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Enable/disable STT (default: true if GROQ_API_KEY is set)
# STT_ENABLED=true

# Whisper model (default: whisper-large-v3)
# STT_MODEL=whisper-large-v3

# ============================================================
# Text-to-Speech (TTS) — Voice Note Replies
# ============================================================

# Enable/disable TTS voice replies to voice notes (default: true)
# TTS_ENABLED=true

# Edge TTS voice (default: en-US-AndrewMultilingualNeural)
# See: https://speech.platform.bing.com/consumer/speech/synthesize/readaloud/voices/list?trustedclienttoken=6A5AA1D4EAFF4E9FB37E23D68491D6F4
# TTS_VOICE=en-US-AndrewMultilingualNeural

# ============================================================
# Discord Bot Configuration (optional — Discord disabled if token absent)
# ============================================================

# Discord Bot token from Discord Developer Portal (optional)
# Enables Discord as a second messaging channel alongside Telegram
DISCORD_BOT_TOKEN=

# Discord Application ID (required when Discord enabled)
# Used for @mention detection — find it in Discord Developer Portal > Application > General Information
DISCORD_APP_ID=

# Comma-separated Discord user IDs allowed to use the bot (required when Discord enabled)
# Discord IDs are snowflake format: 17-20 digit numbers
DISCORD_ALLOWED_USER_IDS=

# Comma-separated Discord channel IDs where the bot can respond (required when Discord enabled)
# Use "*" to allow all channels on the server
DISCORD_ALLOWED_CHANNEL_IDS=

# Comma-separated channel names where the bot responds without @mention (default: "general")
# In all other channels, the bot only responds to @mentions, @everyone, @here, or /commands
# DISCORD_OPEN_CHANNEL_NAMES=general

# ============================================================
# Discord Agent-to-Agent (A2A) Communication (optional)
# ============================================================

# Dedicated Discord channel ID for bot-to-bot communication with Molty
DISCORD_A2A_CHANNEL_ID=

# Molty's Discord bot user ID (required when A2A channel is set)
DISCORD_A2A_PEER_BOT_ID=

# Minimum milliseconds between outbound A2A messages to prevent flooding (default: 5000)
# DISCORD_A2A_RATE_LIMIT_MS=5000

# ============================================================
# Memory System
# ============================================================

# Temporal decay half-life in days for search scoring (default: 30)
# MEMORY_DECAY_HALFLIFE_DAYS=30

# MMR lambda: 1.0 = pure relevance, 0.0 = pure diversity (default: 0.7)
# MEMORY_MMR_LAMBDA=0.7

# Context window compression threshold percentage (default: 85)
# MEMORY_COMPACT_THRESHOLD_PCT=85

# ============================================================
# Web Dashboard (optional — enabled with --web or --all flag)
# ============================================================

# Port for the web dashboard HTTP server (default: 3000)
WEB_PORT=3000

# Host/IP to bind the web dashboard server (default: 127.0.0.1)
# Set to 0.0.0.0 to listen on all interfaces (e.g. behind a reverse proxy)
WEB_HOST=127.0.0.1

# Bearer token for dashboard API and WebSocket authentication (required when --web is enabled)
# Generate a secure random token, e.g.: openssl rand -hex 32
WEB_AUTH_TOKEN=

# Interval in ms between WebSocket status push updates (default: 5000)
# WEB_PUSH_INTERVAL_MS=5000

# ============================================================
# NotebookLM Knowledge Base — Layer 6 (optional)
# ============================================================

# Enable/disable NotebookLM RAG knowledge base layer (default: false)
# NOTEBOOKLM_ENABLED=false

# Path to the notebooklm-mcp-cli project directory
# NOTEBOOKLM_CLI_PATH=/mnt/c/Users/qakosal/workspace/openclaw/notebooklm-mcp-cli

# CLI command timeout in milliseconds (default: 30000)
# NOTEBOOKLM_TIMEOUT_MS=30000

# Default notebook name for queries when --notebook is not specified
# NOTEBOOKLM_DEFAULT_NOTEBOOK=

# Query result cache TTL in milliseconds (default: 300000 = 5 minutes)
# NOTEBOOKLM_QUERY_CACHE_TTL_MS=300000

# --- Agent API (--agent flag) ---
# Comma-separated IPs allowed to connect (required when --agent is enabled)
# AGENT_API_ALLOWED_IPS=192.168.1.50,100.64.4.125
# AGENT_API_PORT=3001
# AGENT_API_TOKEN=
# AGENT_SESSION_KEY=agent:molty
# AGENT_CODENAME=MOLTY
# AGENT_CHAT_ID=1

# Heartbeat interval in seconds (default: 300 = 5 minutes)
# HEARTBEAT_INTERVAL=300

# Daily sleep cycle start time in HH:MM format (default: 06:00)
SLEEP_TIME=06:00

# Google AI Studio — image generation (free tier: 500 images/day)
GOOGLE_AI_API_KEY=

# Embedding search (Se sidecar) — requires ollama + nomic-embed-text
# EMBEDDING_ENABLED=false
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_URL=http://localhost:11434
# EMBEDDING_SIMILARITY_THRESHOLD=0.5
