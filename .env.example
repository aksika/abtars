# ============================================================
# Telegram (required)
# ============================================================

TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=
# POLL_TIMEOUT_S=30
# STREAM_FLUSH_SEC=3

# ============================================================
# Discord (optional)
# ============================================================

# DISCORD_BOT_TOKEN=
# DISCORD_APP_ID=
# DISCORD_ALLOWED_USER_IDS=
# DISCORD_ALLOWED_CHANNEL_IDS=

# ============================================================
# Transport Profile
# ============================================================

# Loads transports/<name>.env — defines model, endpoint, transport type
# Available: kiro, gemini, openrouter, ollama, 9router
AGENT_TRANSPORT_PROFILE=kiro

# ============================================================
# Bridge Settings
# ============================================================

WORKING_DIR=~/.agentbridge/workspace
TRUST_MODE=true
LOG_LEVEL=low
API_DEFAULT_CONTEXT=128000

# ============================================================
# Sleep / Bedtime
# ============================================================

BED_TIME=02:00
WAKE_TIME=07:00
BED_QUIET_TICKS=2
# HARDWARE_SLEEP_AFTER_DREAMY=false
# SLEEP_TIMEOUT_MIN=90

# ============================================================
# Web Dashboard (optional — enabled with --web flag)
# ============================================================

# WEB_PORT=3000
# WEB_HOST=127.0.0.1
# WEB_AUTH_TOKEN=

# ============================================================
# Agent API (optional — enabled with --agent flag)
# ============================================================

# AGENT_API_PORT=3001
# AGENT_API_ALLOWED_IPS=
# AGENT_API_TOKEN=
