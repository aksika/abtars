# AgentBridge Environment Variables
# Generated from env-schema.ts
# Copy to ~/.agentbridge/.env and customize.

# Base directory for runtime data
AGENT_BRIDGE_HOME=

# Agent working directory (default: .)
# WORKING_DIR=.

# Primary Telegram chat ID for notifications
MAIN_CHAT_ID=

# Log level: off, low, debug (default: low)
# LOG_LEVEL=low

# Log format: text or json (default: text)
# LOG_FORMAT=text

# Transport: api, acp, tmux (default: api)
# AGENT_TRANSPORT=api

# Agent CLI name: kiro, gemini (default: kiro)
# AGENT_CLI=kiro

# Override path to agent CLI binary
AGENT_CLI_PATH=

# Main model identifier for agent
AGENT_MAIN_MODEL=

# Default API key for model providers
API_KEY=

# Tmux session name (default: kiro)
# TMUX_SESSION=kiro

# Default transport type (default: api)
# DEFAULT_TRANSPORT=api

# Transport config filename (default: transport.json)
# TRANSPORT_CONFIG=transport.json

# Models config filename (default: models.json)
# MODELS_CONFIG=models.json

# ACP prompt timeout (seconds) (default: 180)
# PROMPT_TIMEOUT_SEC=180

# Direct API model timeout (ms) (default: 120000)
# MODEL_API_TIMEOUT_MS=120000

# Watchdog tool call timeout (seconds) (default: 180)
# WATCHDOG_TOOL_TIMEOUT_SEC=180

# Watchdog silent timeout (seconds) (default: 300)
# WATCHDOG_SILENT_SEC=300

# Watchdog endless loop timeout (seconds) (default: 600)
# WATCHDOG_ENDLESS_SEC=600

# Telegram bot token
TELEGRAM_BOT_TOKEN=

# Telegram API timeout (ms) (default: 15000)
# TELEGRAM_TIMEOUT_MS=15000

# Telegram long-poll timeout (seconds) (default: 30)
# POLL_TIMEOUT_S=30

# Discord bot token
DISCORD_BOT_TOKEN=

# Discord application ID
DISCORD_APP_ID=

# Discord A2A channel ID
DISCORD_A2A_CHANNEL_ID=

# Discord A2A peer bot ID
DISCORD_A2A_PEER_BOT_ID=

# Discord A2A rate limit (ms) (default: 5000)
# DISCORD_A2A_RATE_LIMIT_MS=5000

# Context % to warn user (default: 70)
# CTX_WARN_PCT=70

# Context % to auto-compact (default: 80)
# CTX_COMPACT_PCT=80

# Context % for aggressive compaction (default: 90)
# CTX_AGGRESSIVE_PCT=90

# Context % for idle compaction (default: 65)
# CTX_IDLE_COMPACT_PCT=65

# Minutes idle before floating compaction (default: 10)
# CTX_IDLE_COMPACT_MIN=10

# Typing indicator TTL (ms) (default: 300000)
# TYPING_TTL_MS=300000

# Silent threshold before 'still working' (ms) (default: 90000)
# TYPING_SILENT_THRESHOLD_MS=90000

# Stream edit flush interval (seconds, 0=disabled) (default: 3)
# STREAM_FLUSH_SEC=3

# Enable ambient recall on every turn (default: false)
# ACTIVE_MEMORY=false

# Use model-generated topics for priming (default: true)
# PRIMING_MODEL_TOPICS=true

# Daily sleep trigger time (H:MM or HH:MM) (default: 0:30)
# BED_TIME=0:30

# Wake time for platform detection (default: 7:00)
# WAKE_TIME=7:00

# Quiet heartbeat ticks before sleep (×5min) (default: 2)
# BED_QUIET_TICKS=2

# Enable hardware sleep after Dreamy completes (default: false)
# HARDWARE_SLEEP_AFTER_DREAMY=false

# Model override for Dreamy sleep agent
SLEEP_MODEL=

# Sleep quality override
SLEEP_QUALITY=

# Enable speech-to-text (default: false)
# STT_ENABLED=false

# STT model name (default: whisper-large-v3-turbo)
# STT_MODEL=whisper-large-v3-turbo

# Enable text-to-speech (default: false)
# TTS_ENABLED=false

# TTS voice name (default: alloy)
# TTS_VOICE=alloy

# Enable self-healer task (default: false)
# SELFHEAL_ENABLED=false

# Browser engine: patchright, chromium (default: patchright)
# BROWSER_ENGINE=patchright

# Run browser in headed mode (default: false)
# BROWSER_HEADED=false

# Disable browser sandbox (default: false)
# BROWSER_NO_SANDBOX=false

# Browser channel (e.g. chrome)
BROWSER_CHANNEL=

# Use Docker for browser (default: false)
# BROWSER_DOCKER=false

# Minutes idle before stopping browser container (default: 10)
# BROWSER_IDLE_STOP_MIN=10

# Comma-separated allowed domains
BROWSER_ALLOWED_DOMAINS=

# Browser IPC socket path (default: /run/browser/browser.sock)
# BROWSER_SOCKET_PATH=/run/browser/browser.sock

# Max concurrent browser sessions (default: 3)
# BROWSER_MAX_SESSIONS=3

# Browser session timeout (ms) (default: 300000)
# BROWSER_SESSION_TIMEOUT_MS=300000

# User agent for web scraping
WEB_SCRAPE_USER_AGENT=

# Playwright page timeout (ms) (default: 30000)
# WEB_SCRAPE_PLAYWRIGHT_TIMEOUT_MS=30000

# Enable SSRF protection for browser (default: true)
# SSRF_CHECK=true

# Model override for browsing agent
BROWSING_AGENT=

# Comma-separated capabilities to disable
DISABLED_CAPABILITIES=

# Model override for coding mode
CODING_MODEL=

# Custom dashboard module path
DASHBOARD_MODULE=

# Enable NotebookLM integration (default: false)
# NOTEBOOKLM_ENABLED=false

# Default NotebookLM notebook
NOTEBOOKLM_DEFAULT_NOTEBOOK=

# Permission prompt timeout (ms) (default: 60000)
# PERMISSION_TIMEOUT_MS=60000

# Skip permission prompts (default: false)
# TRUST_MODE=false

