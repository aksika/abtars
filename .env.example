# abtars Environment Variables
# Copied to ~/.abtars/config/.env by `abtars install`.
# Overridden interactively by `abtars onboard`.
#
# Lines starting with `#VAR=value` show the DEFAULT — uncomment to override.
# Lines with `VAR=` (no leading #) are REQUIRED — fill in.

# =====================================================================
# REQUIRED
# =====================================================================

# Telegram bot token from @BotFather (format: <id>:<secret>)
TELEGRAM_BOT_TOKEN=

# Primary Telegram chat ID for cron results + system notifications (numeric)
MAIN_CHAT_ID=

# =====================================================================
# MODEL / PROVIDER (fallback when transport.json is missing)
# =====================================================================

# Default provider name: openrouter, anthropic, openai, ollama, kiro, gemini
DEFAULT_PROVIDER=openrouter

# Default model identifier
DEFAULT_MODEL=google/gemini-2.5-flash

# Set the ONE matching your DEFAULT_PROVIDER
OPENROUTER_API_KEY=
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#KIRO_API_KEY=
#OLLAMA_API_KEY=
#GEMINI_API_KEY=

# =====================================================================
# OPTIONAL — commented lines show defaults
# =====================================================================

# --- Core ---

# Agent working directory / sandbox (default: ~/.abtars/workspace)
#WORKING_DIR=~/.abtars/workspace

# Log level: off (silent), low (operational), debug (full content) (default: low)
#LOG_LEVEL=low

# Log format: text (human) or json (structured) (default: text)
#LOG_FORMAT=text

# Auto-approve all permission requests from the agent (default: false)
#TRUST_MODE=false

# --- Transport ---

# Transport type: api (HTTP), acp (CLI process), tmux (default: api)
#AGENT_TRANSPORT=api

# Agent CLI when transport=acp: kiro or gemini (default: kiro)
#AGENT_CLI=kiro

# Tmux session name when transport=tmux (default: kiro)
#TMUX_SESSION=kiro

# Transport config filename in ~/.abtars/config/ (default: transport.json)
#TRANSPORT_CONFIG=transport.json

# Models catalog filename in ~/.abtars/config/ (default: models.json)
#MODELS_CONFIG=models.json

# --- Transport timeouts + watchdog ---

# ACP prompt timeout in seconds (default: 180)
#PROMPT_TIMEOUT_SEC=180

# Direct API model response timeout in ms (default: 120000)
#MODEL_API_TIMEOUT_MS=120000

# Watchdog timeout for a single tool call in seconds (default: 180)
#WATCHDOG_TOOL_TIMEOUT_SEC=180

# Watchdog timeout for silent/stalled model output in seconds (default: 300)
#WATCHDOG_SILENT_SEC=300

# Watchdog timeout for runaway prompts in seconds (default: 600)
#WATCHDOG_ENDLESS_SEC=600

# Permission prompt timeout in ms — ACP only (default: 60000)
#PERMISSION_TIMEOUT_MS=60000

# --- Telegram ---

# Telegram API timeout in ms (default: 15000)
#TELEGRAM_TIMEOUT_MS=15000

# Telegram long-poll timeout in seconds (default: 30)
#POLL_TIMEOUT_S=30

# Telegram file up/download timeout in ms (default: 60000)
#TELEGRAM_FILE_TIMEOUT_MS=60000

# --- Discord (optional — disabled if bot token absent) ---

# Discord bot token from Developer Portal
#DISCORD_BOT_TOKEN=

# Discord application ID from Developer Portal
#DISCORD_APP_ID=

# Discord A2A (agent-to-agent) channel ID — niche
#DISCORD_A2A_CHANNEL_ID=

# Discord A2A peer bot ID — required if A2A_CHANNEL_ID set
#DISCORD_A2A_PEER_BOT_ID=

# Discord A2A rate limit in ms (default: 5000)
#DISCORD_A2A_RATE_LIMIT_MS=5000

# --- Context window management ---

# Context % to warn user before auto-compact (default: 70)
#CTX_WARN_PCT=70

# Context % to trigger auto-compact (default: 80)
#CTX_COMPACT_PCT=80

# Context % for aggressive compaction (default: 90)
#CTX_AGGRESSIVE_PCT=90

# Context % for floating idle compaction (default: 65)
#CTX_IDLE_COMPACT_PCT=65

# Minutes idle before triggering floating compaction (default: 10)
#CTX_IDLE_COMPACT_MIN=10

# --- UI / streaming ---

# Typing indicator TTL in ms (default: 300000)
#TYPING_TTL_MS=300000

# Silence threshold before 'still working' message in ms (default: 90000)
#TYPING_SILENT_THRESHOLD_MS=90000

# Stream edit flush interval in seconds, 0=disabled (default: 3)
#STREAM_FLUSH_SEC=3

# --- Memory ---

# Enable ambient recall on every turn (default: false)
#ACTIVE_MEMORY=false

# Use model-generated topics for priming (default: true)
#PRIMING_MODEL_TOPICS=true

# --- ABM-L rendering codec (abmind, #236) ---
# These vars are read by abmind. Documented here because abtars
# ships abmind as a dependency — see ~/.abmind/.env.memory.example for details.

# Codec version for memory + context rendering (default: plain)
# Values: plain | v0 | v1
#ABML_VERSION=plain

# --- Three-tier context assembly (abmind, #348) ---
# Progressive compression: tail=verbatim, middle=ABM-L, head=summaries.
# See abmind docs and docs/plans/348-three-tier-context-assembly.md.

# Enable three-tier assembly (default: true)
#CONTEXT_TIER_ENABLED=true

# Tail boundary — last N turns kept verbatim (default: 20)
#CONTEXT_TIER_TAIL=20

# Middle boundary — next M turns rendered as ABM-L (default: 50)
#CONTEXT_TIER_MIDDLE=50

# Enable optional LLM refinement for middle tier (default: false)
# Heuristic is always the fallback.
#COMPACTION_LLM_ENABLED=false

# --- Sleep schedule ---

# Daily sleep trigger time, H:MM or HH:MM (default: 0:30)
#BED_TIME=0:30

# Wake time for platform detection, H:MM or HH:MM (default: 7:00)
#WAKE_TIME=7:00

# Quiet heartbeat ticks (×5min) before sleep is allowed (default: 2)
#BED_QUIET_TICKS=2

# Put machine to hardware sleep after Dreamy finishes (default: false)
#HARDWARE_SLEEP_AFTER_DREAMY=false

# Max minutes for sleep routine before timeout (default: 90)
#SLEEP_TIMEOUT_MIN=90

# Model override for Dreamy sleep agent (default: unset, uses transport.json)
#SLEEP_MODEL=

# Sleep quality override (default: unset)
#SLEEP_QUALITY=

# --- Voice (STT / TTS) ---

# Groq API key for Whisper speech-to-text (voice notes disabled if empty)
#GROQ_API_KEY=

# Auto-enables when GROQ_API_KEY is set (default: derived)
#STT_ENABLED=

# STT model name (default: whisper-large-v3-turbo)
#STT_MODEL=whisper-large-v3-turbo

# Enable text-to-speech voice replies (default: true)
#TTS_ENABLED=true

# TTS voice name (default: alloy)
#TTS_VOICE=alloy

# --- Self-healer ---

# Enable auto-fix heartbeat task (default: false)
#SELFHEAL_ENABLED=false

# --- Browser (optional — web browsing skill) ---

# Browser engine: patchright, chromium (default: patchright)
#BROWSER_ENGINE=patchright

# Run browser headed / visible window for debugging (default: false)
#BROWSER_HEADED=false

# Disable browser sandbox (needed in Docker/root, risky) (default: false)
#BROWSER_NO_SANDBOX=false

# Browser channel, e.g. chrome (default: unset)
#BROWSER_CHANNEL=

# Use Docker container for browser (default: false)
#BROWSER_DOCKER=false

# Minutes idle before stopping browser container (default: 10)
#BROWSER_IDLE_STOP_MIN=10

# Comma-separated domain allowlist for web_browse (default: unset = all)
#BROWSER_ALLOWED_DOMAINS=

# Max concurrent browser sessions (default: 3)
#BROWSER_MAX_SESSIONS=3

# Browser session timeout in ms (default: 300000)
#BROWSER_SESSION_TIMEOUT_MS=300000

# User agent for web scraping (default: unset)
#WEB_SCRAPE_USER_AGENT=

# Playwright page timeout in ms (default: 30000)
#WEB_SCRAPE_PLAYWRIGHT_TIMEOUT_MS=30000

# Enable SSRF protection for outbound HTTP (default: true)
#SSRF_CHECK=true

# Model override for browsing agent (default: unset, uses transport.json)
#BROWSING_AGENT=

# --- Misc ---

# Comma-separated capability names to disable at boot (default: unset)
#DISABLED_CAPABILITIES=

# Model override for coding mode (default: unset, uses transport.json)
#CODING_MODEL=

# Custom dashboard module path (default: unset, uses built-in)
#DASHBOARD_MODULE=

# Enable NotebookLM integration (default: false)
#NOTEBOOKLM_ENABLED=false

# Default NotebookLM notebook (default: unset)
#NOTEBOOKLM_DEFAULT_NOTEBOOK=

# --- Web dashboard (only used with --web flag) ---

# Port for the web dashboard HTTP server (default: 3000)
#WEB_PORT=3000

# Host/IP to bind the web dashboard server (default: 127.0.0.1)
#WEB_HOST=127.0.0.1

# Bearer token for dashboard auth — auto-generated on first --web boot if empty
#WEB_AUTH_TOKEN=

# --- Agent API (only used with --agent flag) ---

# Port for the agent REST API (default: 3100)
#AGENT_API_PORT=3100

# Auth: all tokens live in config/peers.json. Each entry (peer instance or
# operator client like LibreChat/Cursor) gets its own name + token.
# No AGENT_API_TOKEN or AGENT_API_ALLOWED_IPS env vars — peers.json is the
# single source of truth for access control.

# ── Security ──
# off = no restrictions (legacy default)
# guardrails = path guard + command blocklist (recommended)
# sandbox = Docker isolation (future)
SECURITY_MODE=guardrails

# ── Features (explicit opt-in for port-exposing services) ──
ENABLE_DASHBOARD=true
ENABLE_AGENT_API=true
