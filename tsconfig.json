{
    "compilerOptions": {
        "target": "ES2023",
        "module": "Node16",
        "moduleResolution": "Node16",
        "lib": [
            "ES2023"
        ],
        "outDir": "dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "isolatedModules": true,
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "paths": {
            "@agentbridge/memory": ["./packages/memory/src/index.ts"],
            "@agentbridge/memory/*": ["./packages/memory/src/*"]
        }
    },
    "include": [
        "src/**/*.ts",
        "packages/memory/src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts"
    ]
}
