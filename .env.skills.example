# ─── Skill Settings ───
# Non-secret configuration for skills (URLs, flags, model names, voices).
# API keys and tokens belong in ~/.abtars/secret/ (encrypted at rest).
# Drop a file named after the env var: echo "sk-xxx" > ~/.abtars/secret/GROQ_API_KEY
#
# If you accidentally put a key here (uncommented), it will be auto-migrated
# to secret/ on next boot. Commented examples below are safe — boot ignores them.
# ============================================================

# ============================================================
# Speech-to-Text / Text-to-Speech
# ============================================================

# GROQ_API_KEY=<your-key-here>  ← put in secret/ instead
# STT_MODEL=whisper-large-v3
# TTS_ENABLED=true
# TTS_VOICE=en-US-AndrewMultilingualNeural

# ============================================================
# Home Assistant
# ============================================================

# HA_URL=http://192.168.1.4:8123
# HA_TOKEN=<your-token-here>  ← put in secret/ instead

# ============================================================
# NotebookLM
# ============================================================

# NOTEBOOKLM_ENABLED=false
# NOTEBOOKLM_CLI_PATH=

# ============================================================
# Google AI Studio (image generation)
# ============================================================

# GOOGLE_AI_API_KEY=<your-key-here>  ← put in secret/ instead
# GOOGLE_AI_MODEL=gemini-2.0-flash-preview-image-generation
