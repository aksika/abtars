# ============================================================
# Skill & Integration Settings
# ============================================================
# This file is never touched by deploy. Edit directly.
# Created from .env.skills.example on first deploy.

# ============================================================
# Speech-to-Text / Text-to-Speech
# ============================================================

GROQ_API_KEY=
# STT_MODEL=whisper-large-v3
# TTS_ENABLED=true
# TTS_VOICE=en-US-AndrewMultilingualNeural

# ============================================================
# Home Assistant
# ============================================================

# HA_URL=http://192.168.1.4:8123
# HA_TOKEN=

# ============================================================
# Embedding (requires ollama or TogetherAI)
# ============================================================

# EMBEDDING_ENABLED=false
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_URL=http://localhost:11434
# EMBEDDING_SIMILARITY_THRESHOLD=0.5
# TOGETHERAI_API_ID=
# TOGETHERAI_API_KEY=

# ============================================================
# NotebookLM
# ============================================================

# NOTEBOOKLM_ENABLED=false
# NOTEBOOKLM_CLI_PATH=

# ============================================================
# Google AI Studio (image generation — free tier: 500 images/day)
# ============================================================

# GOOGLE_AI_API_KEY=
