<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.agentbridge.watchdog</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/akos/.agentbridge/watchdog.sh</string>
    <string>--all</string>
    <string>--web</string>
    <string>--agent</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>StandardOutPath</key>
  <string>/Users/akos/.agentbridge/logs/watchdog-launchd.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/akos/.agentbridge/logs/watchdog-launchd.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/akos/.agentbridge/bin:/Users/akos/.local/bin:/Users/akos/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
