{
  "identity": {
    "privateKey": "<base64 Ed25519 private key — generated by abtars install>",
    "publicKey": "<base64 Ed25519 public key>"
  },
  "servers": [
    {
      "id": "example",
      "host": "127.0.0.1",
      "port": 6667,
      "tls": false,
      "nick": "Alice",
      "channels": {
        "#general": {
          "mode": "plain",
          "requireMention": true,
          "allowFrom": ["Bob", "JohnDoe"]
        },
        "#secure": {
          "mode": "signed",
          "requireMention": false,
          "trustedKeys": {
            "Bob": "<base64 Ed25519 public key of Bob>"
          },
          "allowUnsigned": ["JohnDoe!john@192.168.1.10"]
        }
      }
    }
  ]
}
