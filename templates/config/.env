# abtars configuration
# Run `abtars install` to configure. See .env.example for all options.

# ── Memory ──
MEMORY=abmind
ACTIVE_MEMORY=true

# ── Agent Behavior ──
LOG_LEVEL=trace
SELFHEAL_ENABLED=true
ENABLE_AGENT_API=true

# ── Sleep Schedule ──
BED_TIME=00:30
WAKE_TIME=06:00

# ── Context Window ──
#CTX_WARN_PCT=70
#CTX_COMPACT_PCT=80

# ── Typing ──
TYPING_TTL_MS=120000

# ── Discord ──
#DISCORD_A2A_CHANNEL_ID=
#DISCORD_GROUP_MENTIONS=required
#DISCORD_ALLOW_BOTS=none
#DISCORD_FREE_CHANNELS=

# ── Dashboard ──
#ENABLE_DASHBOARD=false
#WEB_PORT=3000
