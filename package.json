{
  "name": "agentbridge",
  "version": "0.1.0",
  "description": "Standalone agent bridging Telegram to Kiro CLI via tmux/ACP",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && cp -r src/public dist/public && git log -1 --format='{\"hash\":\"%h\",\"date\":\"%ci\"}' > dist/build-info.json",
    "dev": "node --import tsx src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@andresaya/edge-tts": "^1.8.0",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.7",
    "file-type": "^22.0.0",
    "patchright": "^1.58.2",
    "pdf-parse": "^2.4.5",
    "rettiwt-api": "^6.2.1",
    "ws": "^8.19.0",
    "youtube-transcript": "^1.2.1",
    "abmind": "file:../abmind"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "fast-check": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "bin": {
    "agentbridge-browser": "dist/cli/agentbridge-browser.js",
    "agentbridge-tweet": "dist/cli/agentbridge-tweet.js",
    "agentbridge-sleep": "dist/cli/agentbridge-sleep.js",
    "agentbridge-restart": "dist/cli/agentbridge-restart.js"
  },
  "license": "Apache-2.0"
}
