{
  "name": "agentbridge",
  "version": "0.1.0",
  "description": "Standalone agent bridging Telegram to Kiro CLI via tmux/ACP",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && cp -r src/public dist/public && git log -1 --format='{\"hash\":\"%h\",\"date\":\"%ci\"}' > dist/build-info.json",
    "bundle": "cd ../abmind && npm run build && cd ../agentbridge && node esbuild.config.js && cp -r src/public bundle/public",
    "dev": "node --import tsx src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@andresaya/edge-tts": "^1.8.0",
    "@clack/prompts": "^1.2.0",
    "abmind": "file:../abmind",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.26.3",
    "dotenv": "^16.6.1",
    "file-type": "^22.0.1",
    "patchright": "^1.59.4",
    "pdf-parse": "^2.4.5",
    "rettiwt-api": "^6.2.2",
    "ws": "^8.20.0",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "esbuild": "0.25.4",
    "fast-check": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "bin": {
    "agentbridge": "dist/cli/agentbridge.js",
    "agentbridge-browser": "dist/cli/agentbridge-browser.js",
    "agentbridge-tweet": "dist/cli/agentbridge-tweet.js"
  },
  "license": "Apache-2.0"
}
