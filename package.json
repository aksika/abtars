{
  "name": "abtars",
  "version": "0.1.0",
  "description": "Standalone agent bridging Telegram to Kiro CLI via tmux/ACP",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && rm -rf dist/components/dashboard/public && cp -r src/components/dashboard/public dist/components/dashboard/public && git log -1 --format='{\"hash\":\"%h\",\"date\":\"%ci\"}' > dist/build-info.json",
    "bundle": "cd ../abmind && npm run build && cd ../abtars && node esbuild.config.js && rm -rf bundle/public && cp -r src/components/dashboard/public bundle/public",
    "dev": "node --import tsx src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "check-imports": "bash -c '! grep -rE \"from \\\"abmind/|from '\\''abmind/\" src --include=*.ts | grep -vE \"abmind/deploy-lib\\\"|abmind/deploy-lib'\\''\"'",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@andresaya/edge-tts": "^1.8.0",
    "@clack/prompts": "^1.2.0",
    "abmind": "file:../abmind",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.26.3",
    "dotenv": "^16.6.1",
    "file-type": "^22.0.1",
    "patchright": "^1.59.4",
    "pdf-parse": "^2.4.5",
    "ws": "^8.20.0",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "esbuild": "0.25.4",
    "fast-check": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "bin": {
    "abtars": "dist/cli/abtars.js",
    "abtars-browser": "dist/cli/abtars-browser.js",
    "abtars-task": "dist/cli/abtars-task.js",
    "abtars-tweet": "dist/cli/abtars-tweet.js"
  },
  "license": "Apache-2.0",
  "optionalDependencies": {
    "rettiwt-api": "^6.2.2"
  }
}
