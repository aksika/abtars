FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl git && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY bundle/ ./bundle/
COPY core/ ./core/

# Workspace mount point
VOLUME /workspace
ENV ABTARS_SANDBOX=1

ENTRYPOINT ["node", "bundle/abtars.js", "--session"]
