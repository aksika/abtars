# ABM — AgentBridge Memory Configuration

# Search mode: hybrid (best), embedding (legacy), signature (no ollama needed)
MEMORY_SEARCH_MODE=hybrid

# Storage limit (MB). Aging accelerates as DB approaches this limit. 0 = unlimited.
MEMORY_MAX_DB_SIZE_MB=4096

# Three-tier aging: English (redundant once ABM-L exists) → Original → ABM-L forever
MEMORY_AGING_ENABLED=true
MEMORY_ENGLISH_TTL_DAYS=14
MEMORY_ORIGINAL_TTL_DAYS=90

# Binary signature size (bits). 256 = 32 bytes per memory.
SIGNATURE_BITS=256

# Embedding (only used when MEMORY_SEARCH_MODE=hybrid or embedding)
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_URL=http://localhost:11434

# ============================================================
# Recall tuning
# ============================================================

MEMORY_DECAY_HALFLIFE_DAYS=30
MEMORY_MMR_LAMBDA=0.7

# ============================================================
# Context window compaction thresholds
# ============================================================

CTX_WARN_PCT=70
CTX_COMPACT_PCT=85
